# ============================================================================
# freekoko — .gitignore
#
# Committed: source, config, Makefile, lockfiles (package-lock.json,
#   Package.resolved), planning docs, scripts, tray icon placeholders, NOTES.md.
# Ignored:   build outputs, dependency caches, model weights, logs, env files,
#   editor/OS cruft.
# ============================================================================

# --- macOS ---------------------------------------------------------------
.DS_Store
._*
.AppleDouble
.LSOverride
Icon?

# --- IDEs / editors ------------------------------------------------------
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.cursor/
*.swp
*.swo
*~
.sourcekit-lsp/

# --- Claude / agent local state ------------------------------------------
.claude/

# --- Swift / Xcode (freekoko-sidecar, upstream-kokoro) -------------------
.build/
.swiftpm/
*.xcodeproj/
*.xcworkspace/
xcuserdata/
*.xcuserstate
DerivedData/
*.dSYM/

# Compiled Metal shader artifacts (regenerated by xcodebuild)
*.metallib
*.air

# Coverage raw profile files (vitest / swift test)
*.profraw
*.profdata

# --- Node.js / Electron / Vite / TypeScript (freekoko-app) ---------------
node_modules/
out/
dist/
.vite/
.eslintcache
coverage/
.nyc_output/
*.tsbuildinfo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env files (keep .env.example if one exists)
.env
.env.*
!.env.example

# --- Kokoro model weights (too large for git; fetch with `make download-models`)
upstream-kokoro/Resources/*.safetensors
upstream-kokoro/Resources/voices/
upstream-kokoro/Resources/*.npz
upstream-kokoro/Resources/*.pt
upstream-kokoro/Resources/config.json

# --- Release artifacts (electron-builder output) -------------------------
*.dmg
*.dmg.sha256
*.blockmap
*.zip
latest-mac.yml

# --- Runtime state generated by the app in dev ---------------------------
# electron-store and electron-log write here via app.getPath('userData'/'logs')
# These paths are OS-managed and already outside the repo, but guard against
# anything that slips in under freekoko-app/.
freekoko-app/userData/
freekoko-app/logs/

# --- Misc temp / backup --------------------------------------------------
*.tmp
*.bak
.#*
prd.md